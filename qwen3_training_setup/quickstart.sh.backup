#!/bin/bash
# Quick Start Script for Qwen3-0.6B Training Setup
# 
# This script provides copy-paste commands to get started quickly.
# Review each section before running!

set -e  # Exit on error

echo "=================================================="
echo "Qwen3-0.6B Training Setup - Quick Start"
echo "=================================================="
echo ""

# ============================================================================
# STEP 1: Environment Setup
# ============================================================================
echo "STEP 1: Environment Setup"
echo "------------------------"
echo ""
echo "Run these commands:"
echo ""
echo "  cd /home/ghadimi/projects/aip-aghodsib/ghadimi/ARMD-transformers/qwen3_training_setup"
echo "  uv venv .venv"
echo "  source .venv/bin/activate"
echo "  uv sync"
echo ""
read -p "Press Enter after running the above commands..."

# ============================================================================
# STEP 2: Weights & Biases Setup
# ============================================================================
echo ""
echo "STEP 2: Weights & Biases Setup"
echo "------------------------------"
echo ""
echo "Login to wandb for training metrics logging:"
echo ""
echo "  wandb login"
echo ""
echo "Get your API key from: https://wandb.ai/authorize"
echo ""
echo "This enables real-time training monitoring at https://wandb.ai"
echo ""
read -p "Press Enter after logging in to wandb..."

# ============================================================================
# STEP 3: Verify Installation
# ============================================================================
echo ""
echo "STEP 3: Verify Installation"
echo "---------------------------"
echo ""
echo "Run these commands to verify:"
echo ""
echo "  python -c \"import torch; print(f'PyTorch: {torch.__version__}')\""
echo "  python -c \"import transformers; print(f'Transformers: {transformers.__version__}')\""
echo "  python -c \"import torch; print(f'CUDA available: {torch.cuda.is_available()}')\""
echo "  python -c \"import wandb; print(f'wandb: {wandb.__version__}')\""
echo ""
read -p "Press Enter after verifying installation..."

# ============================================================================
# STEP 4: GPU Allocation (if using SLURM)
# ============================================================================
echo ""
echo "STEP 4: GPU Allocation (SLURM)"
echo "------------------------------"
echo ""
echo "If using SLURM, allocate GPU with:"
echo ""
echo "  cd /home/ghadimi/projects/aip-aghodsib/ghadimi/ARMD-transformers"
echo "  salloc --account=aip-aghodsib --time=01:00:00 --cpus-per-task=8 --mem=32G --gres=gpu:1"
echo ""
echo "After allocation, return and activate environment:"
echo ""
echo "  cd qwen3_training_setup"
echo "  source .venv/bin/activate"
echo ""
read -p "Press Enter after GPU allocation (or skip if not using SLURM)..."

# ============================================================================
# STEP 4: Run Smoke Test
# ============================================================================
echo ""
echo "STEP 5: Run Smoke Test"
echo "---------------------"
echo ""
echo "Test that everything works:"
echo ""
echo "  python scripts/inference_test.py"
echo ""
echo "Expected: All 4 tests should PASS"
echo ""
read -p "Press Enter after smoke test passes..."

# ============================================================================
# STEP 6: Training Options
# ============================================================================
echo ""
echo "STEP 6: Choose Training Mode"
echo "----------------------------"
echo ""
echo "Option A: Quick Test with fineweb-edu (Recommended First)"
echo "=========================================================="
echo ""
echo "  python scripts/train.py --max_samples 10000"
echo ""
echo "This uses HuggingFace's fineweb-edu dataset (no data prep needed!)"
echo "Logs to wandb at https://wandb.ai"
echo ""
echo ""
echo "Option B: Full Training on fineweb-edu"
echo "======================================"
echo ""
echo "  python scripts/train.py \\"
echo "      --max_samples 100000 \\"
echo "      --num_train_epochs 1 \\"
echo "      --per_device_train_batch_size 4 \\"
echo "      --learning_rate 2e-5 \\"
echo "      --output_dir ./outputs/qwen3_fineweb"
echo ""
echo ""
echo "Option C: Use Your Own Dataset"
echo "==============================="
echo ""
echo "  python scripts/train.py \\"
echo "      --dataset_path data/train.txt \\"
echo "      --num_train_epochs 3 \\"
echo "      --per_device_train_batch_size 4 \\"
echo "      --learning_rate 2e-5 \\"
echo "      --output_dir ./outputs/qwen3_custom \\"
echo "      --create_sample_data"
echo ""
echo ""
echo "Option D: Training with Layer Surgery"
echo "======================================"
echo ""
echo "  python scripts/train_with_surgery.py \\"
echo "      --replace_layers 12,13,14 \\"
echo "      --max_samples 10000 \\"
echo "      --output_dir ./outputs/qwen3_modified"
echo ""
echo ""
echo "Option E: Use Tensorboard Instead of wandb"
echo "==========================================="
echo ""
echo "  python scripts/train.py \\"
echo "      --report_to tensorboard \\"
echo "      --max_samples 10000"
echo ""
echo ""
echo "See example_train_commands.sh for more examples!"
echo ""
read -p "Press Enter to continue..."

# ============================================================================
# STEP 7: Monitor Training
# ============================================================================
echo ""
echo "STEP 7: Monitor Training"
echo "------------------------"
echo ""
echo "Default: Weights & Biases"
echo "========================="
echo "  Visit https://wandb.ai to see real-time training metrics"
echo ""
echo ""
echo "Alternative: Tensorboard (if using --report_to tensorboard)"
echo "==========================================================="
echo "  In another terminal, run:"
echo ""
echo "  cd /home/ghadimi/projects/aip-aghodsib/ghadimi/ARMD-transformers/qwen3_training_setup"
echo "  source .venv/bin/activate"
echo "  tensorboard --logdir outputs/*/runs"
echo ""
echo "  Then open the URL in your browser."
echo "----------------------------"
echo ""
echo "Option A: Standard Full Fine-tuning"
echo "====================================="
echo ""
echo "  python scripts/train.py \\"
echo "      --model_name Qwen/Qwen3-0.6B \\"
echo "      --dataset_path data/train.txt \\"
echo "      --output_dir ./outputs/qwen3_finetuned \\"
echo "      --num_train_epochs 3 \\"
echo "      --per_device_train_batch_size 4 \\"
echo "      --learning_rate 2e-5 \\"
echo "      --create_sample_data"
echo ""
echo "Option B: Training with Layer Surgery"
echo "======================================"
echo ""
echo "  python scripts/train_with_surgery.py \\"
echo "      --model_name Qwen/Qwen3-0.6B \\"
echo "      --dataset_path data/train.txt \\"
echo "      --output_dir ./outputs/qwen3_modified \\"
echo "      --replace_layers 12,13,14 \\"
echo "      --num_train_epochs 3 \\"
echo "      --per_device_train_batch_size 4 \\"
echo "      --create_sample_data"
echo ""
echo "Option C: Quick Test (10 steps)"
echo "================================"
echo ""
echo "  python scripts/train.py \\"
echo "      --max_steps 10 \\"
echo "      --output_dir ./outputs/test_run \\"
echo "      --create_sample_data"
echo ""
read -p "Press Enter to continue..."

# ============================================================================
# STEP 6: Monitor Training
# ============================================================================
echo ""
echo "STEP 6: Monitor Training (Optional)"
echo "-----------------------------------"
echo ""
echo "In another terminal, run:"
echo ""
echo "  cd /home/ghadimi/projects/aip-aghodsib/ghadimi/ARMD-transformers/qwen3_training_setup"
echo "  source .venv/bin/activate"
echo "  tensorboard --logdir outputs/qwen3_finetuned/runs"
echo ""
echo "Then open the URL in your browser."
echo ""
read -p "Press Enter to continue..."

# ============================================================================
# Summary
# ============================================================================
echo ""
echo "=================================================="
echo "Setup Complete!"
echo "=================================================="
echo ""
echo "📚 Documentation:"
echo "   - README.md           : Main overview"
echo "   - SETUP.md            : Detailed setup instructions"
echo "   - IMPLEMENTATION.md   : Architecture and design details"
echo "   - CHECKLIST.md        : Verification checklist"
echo ""
echo "🚀 Next Steps:"
echo "   1. Choose a training command from Step 5"
echo "   2. Run the command"
echo "   3. Monitor training progress"
echo "   4. Use your trained model!"
echo ""
echo "💡 Tips:"
echo "   - Start with Option C (quick test) to verify setup"
echo "   - Monitor GPU with: nvidia-smi"
echo "   - Check logs in: outputs/*/runs"
echo ""
echo "❓ Need Help?"
echo "   - See SETUP.md for troubleshooting"
echo "   - Check CHECKLIST.md for verification steps"
echo "   - Review IMPLEMENTATION.md for architecture details"
echo ""
